	<!--GLOBE #2 Set of Enumerations - 201 to 205 - ID Type - Rules-->
	<xsd:simpleType name="IDTypeRules_EnumType">
		<xsd:annotation>
			<xsd:documentation>ID Type - Rules [Zasady Opodatkowania Wyrównawczego]</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="GIR201">
				<xsd:annotation>
					<xsd:documentation>QIIR applicable to Low-Taxed Constituent Entities located in other jurisdictions only [Kwalifikowany globalny podatek wyrównawczy (QIIR) ma zastosowanie wyłącznie do nisko opodatkowanych jednostek składowych zlokalizowanych w innych jurysdykcjach]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR202">
				<xsd:annotation>
					<xsd:documentation>QIIR applicable to both Low-Taxed Constituent Entities located in other jurisdictions and in the jurisdiction of the Parent Entity [Kwalifikowany globalny podatek wyrównawczy (QIIR) ma zastosowanie zarówno wobec nisko opodatkowanych jednostek składowych w innych jurysdykcjach, jak i w jurysdykcji jednostki dominującej]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR203">
				<xsd:annotation>
					<xsd:documentation>QUTPR [Kwalifikowany podatek wyrównawczy od niedostatecznie opodatkowanych zysków (QUTPR)]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR204">
				<xsd:annotation>
					<xsd:documentation>QDMTT [Kwalifikowany krajowy podatek wyrównawczy (QDMTT)]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR205">
				<xsd:annotation>
					<xsd:documentation>Not applicable [Nie dotyczy]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
