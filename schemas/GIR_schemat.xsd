	<!--GLOBE #3 Set of Enumerations - 301 to 317 - ID Type - GloBEStatus-->
	<xsd:simpleType name="IDTypeGloBEStatus_EnumType">
		<xsd:annotation>
			<xsd:documentation>ID Type - GloBEStatus [Typ identyfikatora – Status GloBE]</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="GIR301">
				<xsd:annotation>
					<xsd:documentation>Constituent Entity [Jednostka składowa]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR302">
				<xsd:annotation>
					<xsd:documentation>Flow-Through Entity – Tax Transparent [Jednostka pośrednicząca - jednostka transparentna podatkowo]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR303">
				<xsd:annotation>
					<xsd:documentation>Flow-Through Entity – Reverse Hybrid [Jednostka pośrednicząca - odwrócona jednostka hybrydowa]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR304">
				<xsd:annotation>
					<xsd:documentation>Hybrid Entity [Jednostka hybrydowa]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR305">
				<xsd:annotation>
					<xsd:documentation>Permanent Establishment [Stały zakład]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR306">
				<xsd:annotation>
					<xsd:documentation>Main Entity [Centrala]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR307">
				<xsd:annotation>
					<xsd:documentation>Minority-Owned Parent Entity [Mniejszościowa jednostka dominująca]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR308">
				<xsd:annotation>
					<xsd:documentation>Minority-Owned Subsidiary [Mniejszościowa jednostka zależna]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR309">
				<xsd:annotation>
					<xsd:documentation>Minority-Owned Constituent Entity [Mniejszościowa jednostka składowa]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="GIR310">
				<xsd:annotation>
					<xsd:documentation>Investment Entity [Jednostka inwestycyjna]</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
